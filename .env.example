# === GitHub ===
# Token mit repo + write:issues Scope
# Erstellen: https://github.com/settings/tokens/new (classic, Scope: repo)
# Aktueller Token: gh auth token
GH_TOKEN=ghp_your_token_here
GITHUB_TOKEN=ghp_your_token_here

# === Anthropic (optional - nur wenn claude_cli Agent als Fallback) ===
# Leer lassen wenn nur Ollama verwendet wird
ANTHROPIC_API_KEY=

# === Ollama (Tailscale URL zum Windows/Linux-PC mit GPU) ===
# Format: http://100.x.y.z:11434
# Lokal: http://localhost:11434
# Remote (Tailscale): http://100.111.112.15:11434
OLLAMA_TAILSCALE_URL=http://localhost:11434

# === Slack (optional - Webhook fuer Benachrichtigungen) ===
SLACK_WEBHOOK_URL=

# === Task-Limits ===
TASK_MAX_ITERS=25

# === GitHub Webhook Secret (optional) ===
GITHUB_WEBHOOK_SECRET=
