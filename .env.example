# === GitHub ===
# Token mit repo + write:issues Scope
# gh auth token  ->  gibt deinen aktuellen Token aus
GH_TOKEN=ghp_your_token_here
GITHUB_TOKEN=ghp_your_token_here

# === Anthropic (optional - nur wenn sonnet-Agent genutzt wird) ===
ANTHROPIC_API_KEY=

# === Ollama (optional - Tailscale URL zum Windows/Linux-PC mit GPU) ===
# Format: http://100.x.y.z:11434
# OLLAMA_BASE_URL=http://100.111.112.15:11434

# === Slack (optional - Webhook fuer Benachrichtigungen) ===
SLACK_WEBHOOK_URL=

# === Task-Limits ===
TASK_MAX_ITERS=25
TASK_USD_CAP=10
